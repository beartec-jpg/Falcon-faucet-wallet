# ─── Required environment variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# xrpld public RPC endpoint (port 6005 only — use public nodes, never admin ports)
XRPLD_RPC_URL=http://46.224.0.140:6005

# Falcon faucet account — funded on the Falcon testnet (Network ID 1001)
FAUCET_ACCOUNT=rBiUgMfG4Me7epQ3sC8hbbQuMWUPdq9jjJ
FAUCET_SECRET=<falcon_secret from faucet.json — never commit>

# Falcon signing proxy on node1 (admin RPC bridge)
SIGNER_PROXY_URL=http://46.224.0.140:3001
SIGNER_PROXY_TOKEN=<bearer token — never commit>

# Amount to send per drip (in qXRP, NOT drops)
DRIP_AMOUNT_QXRP=2000

# Rate limiting: 1 request per window per IP and per account
RATE_LIMIT_REQUESTS=1
RATE_LIMIT_WINDOW_SECONDS=86400

# Upstash Redis (for distributed rate limiting on Vercel)
KV_REST_API_URL=https://YOUR_UPSTASH_URL.upstash.io
KV_REST_API_TOKEN=YOUR_UPSTASH_TOKEN

# Stablecoins — fill in after re-issuing on the new chain (leave empty until then)
NEXT_PUBLIC_QUSDC_CURRENCY=QUC
NEXT_PUBLIC_QUSDC_ISSUER=
NEXT_PUBLIC_QUSDT_CURRENCY=QUT
NEXT_PUBLIC_QUSDT_ISSUER=

# Public env vars (exposed to browser)
NEXT_PUBLIC_NETWORK_NAME=qXRP Falcon Testnet
NEXT_PUBLIC_NETWORK_ID=1001
NEXT_PUBLIC_DRIP_AMOUNT_QXRP=2000
NEXT_PUBLIC_RPC_URL=http://46.224.0.140:6005
NEXT_PUBLIC_EXPLORER_URL=