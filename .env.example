# ─── Required environment variables ──────────────────────────────────────────
# Copy to .env.local (dev) and Vercel env (production). NEVER commit secrets.

# ═══════════════════════════════════════════════════════════════════════════
# TESTNET (Network ID 1001) — live today
# ═══════════════════════════════════════════════════════════════════════════

XRPLD_RPC_URL=https://46.224.0.140:6005
# Signed tx_blobs traverse this channel — use https:// (TLS) to prevent MITM.
# Plaintext http:// is refused on the submit path in production unless
# ALLOW_INSECURE_TRANSPORT=true is set (trusted-network opt-in only).
# Legacy aliases (optional):
# XRPLD_TESTNET_RPC_URL=https://46.224.0.140:6005

# From coordinator: /root/qxrp-bootstrap/faucet.json (chmod 600)
TESTNET_FAUCET_ACCOUNT=rwzhiWW4GYK2sQVR5Lw4iDpYLANB5krJXY
TESTNET_FAUCET_SECRET=<falcon_secret from faucet.json — never commit>
# Legacy aliases (optional):
# FAUCET_ACCOUNT=...
# FAUCET_SECRET=...

TESTNET_DRIP_AMOUNT_QXRP=2000
SIGNER_PROXY_URL=https://46.224.0.140:3001
SIGNER_PROXY_TOKEN=<bearer token — never commit>
# Prefer https:// (TLS/mTLS or an SSH tunnel). Only if the proxy is reachable
# over plaintext http:// on a trusted network, explicitly opt in below.
ALLOW_INSECURE_TRANSPORT=false

NEXT_PUBLIC_TESTNET_NAME=Falcon Ledger Testnet
NEXT_PUBLIC_TESTNET_NETWORK_ID=1001
NEXT_PUBLIC_TESTNET_RPC_URL=https://46.224.0.140:6005
NEXT_PUBLIC_TESTNET_DRIP_QXRP=2000
NEXT_PUBLIC_TESTNET_EXPLORER_URL=

# Testnet USDC (Falcon ledger IOU until MPT bridge live)
# Or serve issuer from public/config/testnet-stables.json (auto-fallback when empty)
NEXT_PUBLIC_TESTNET_USDC_CURRENCY=QUC
# Leave empty to use public/config/testnet-stables.json (rsJoDhj… post-genesis)
NEXT_PUBLIC_TESTNET_USDC_ISSUER=rsJoDhjVV78jr6huHxKjtT8uG8RGeGmd1N

# Sepolia bridge (in-app passkey EVM wallet + optional external wallet)
SEPOLIA_LOCK_CONTRACT=0x2dae31Cbf2E3a418d617081985661fCD0117b75C
SEPOLIA_USDC_TOKEN=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
NEXT_PUBLIC_SEPOLIA_LOCK_CONTRACT=0x2dae31Cbf2E3a418d617081985661fCD0117b75C
NEXT_PUBLIC_SEPOLIA_USDC_TOKEN=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# ═══════════════════════════════════════════════════════════════════════════
# MAINNET — configure before launch; keep NEXT_PUBLIC_MAINNET_LIVE=false until go-live
# ═══════════════════════════════════════════════════════════════════════════

# DECISION REQUIRED: pick mainnet Network ID (must differ from 1001)
NEXT_PUBLIC_MAINNET_NETWORK_ID=1
NEXT_PUBLIC_MAINNET_NAME=Falcon Ledger
NEXT_PUBLIC_MAINNET_LIVE=false
NEXT_PUBLIC_MAINNET_RPC_URL=
NEXT_PUBLIC_MAINNET_DRIP_QXRP=100
NEXT_PUBLIC_MAINNET_EXPLORER_URL=

MAINNET_RPC_URL=
MAINNET_FAUCET_ACCOUNT=
MAINNET_FAUCET_SECRET=
# Bootstrap: fund faucet from genesis circulating tranche (2% = 4B qXRP total supply).
# Recommended initial faucet balance: 10–25M qXRP (see MAINNET_FAUCET_BOOTSTRAP_QXRP in networks.ts).
MAINNET_DRIP_AMOUNT_QXRP=100
MAINNET_SIGNER_PROXY_URL=
MAINNET_SIGNER_PROXY_TOKEN=

NEXT_PUBLIC_MAINNET_USDC_CURRENCY=USC
NEXT_PUBLIC_MAINNET_USDC_ISSUER=
NEXT_PUBLIC_MAINNET_COMING_SOON=Mainnet launches soon. Use Testnet to try the wallet.

# Lending broker co-sign (liquidity provider falcon_secret — server only, never commit)
# Copy from coordinator /var/lib/qxrp-stables/stables_state.json → liquidity_provider.falcon_secret
TESTNET_LENDING_BROKER_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# Message board (Neon Postgres)
# ═══════════════════════════════════════════════════════════════════════════

# From Neon dashboard → Connection string (pooled or direct)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Vercel Neon integration may also set POSTGRES_URL — either works.

# ═══════════════════════════════════════════════════════════════════════════
# Shared
# ═══════════════════════════════════════════════════════════════════════════

RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=3600
# Explorer 24h charts: uses DATABASE_URL (Neon) when set — no Redis required.
# Optional Upstash Redis is used only if Neon is not configured.
# KV_REST_API_URL=https://YOUR_UPSTASH_URL.upstash.io
# KV_REST_API_TOKEN=YOUR_UPSTASH_TOKEN
# CRON_SECRET=random-string   # Required on Vercel for /api/cron/sample-metrics (openssl rand -hex 32)
# Set RATE_LIMIT_FAIL_OPEN=true to disable rate limiting entirely.
# RATE_LIMIT_FAIL_OPEN=false

# ALLOWED_ORIGINS=https://your-wallet.example.com
# ALLOW_INSECURE_TRANSPORT=false