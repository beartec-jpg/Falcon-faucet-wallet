# ─── Required environment variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# xrpld public RPC endpoint (port 6005 only — use public nodes, never admin ports)
XRPLD_RPC_URL=http://46.224.0.140:6005

# Falcon faucet account — funded on the Falcon testnet (Network ID 1001)
FAUCET_ACCOUNT=rBiUgMfG4Me7epQ3sC8hbbQuMWUPdq9jjJ
FAUCET_SECRET=<falcon_secret from faucet.json — never commit>

# Falcon signing proxy on node1 (admin RPC bridge)
SIGNER_PROXY_URL=http://46.224.0.140:3001
SIGNER_PROXY_TOKEN=<bearer token — never commit>

# Amount to send per drip (in qXRP, NOT drops)
DRIP_AMOUNT_QXRP=2000

# Rate limiting: 1 request per window per IP and per account
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=3600

# Upstash Redis (REQUIRED in production for distributed rate limiting on Vercel).
# Without it the faucet fails CLOSED in production (drips are rejected) to prevent
# the funded faucet account from being drained. Set RATE_LIMIT_FAIL_OPEN=true only
# if you knowingly accept an unlimited faucet.
KV_REST_API_URL=https://YOUR_UPSTASH_URL.upstash.io
KV_REST_API_TOKEN=YOUR_UPSTASH_TOKEN
# RATE_LIMIT_FAIL_OPEN=false

# CSRF protection: comma-separated list of allowed site origins for state-changing
# API routes (faucet/submit). REQUIRED in production — when unset, those routes
# fail closed (deny) in production.
# ALLOWED_ORIGINS=https://your-wallet.example.com

# SSRF protection for the validator node-dashboard proxy. Optional allow-list of
# validator hosts/IPs that may be proxied. Internal/loopback/private addresses are
# always blocked regardless of this list.
# ALLOWED_DASHBOARD_HOSTS=node1.example.com,46.224.0.140

# Transport security: SIGNER_PROXY_URL / XRPLD_RPC_URL should use https:// in
# production. Plain HTTP exposes the signer bearer token and signed tx_blobs to
# MITM. Set ALLOW_INSECURE_TRANSPORT=true to explicitly accept plaintext HTTP on
# a trusted network (not recommended).
# ALLOW_INSECURE_TRANSPORT=false

# Legacy server-side signing endpoint (/api/wallet/sign) is DISABLED by default
# because it forwards falcon_secret to the server. Enable only for legacy
# integrations that cannot sign in-browser.
# ENABLE_LEGACY_SIGN=false

# Stablecoins — fill in after re-issuing on the new chain (leave empty until then)
NEXT_PUBLIC_QUSDC_CURRENCY=QUC
NEXT_PUBLIC_QUSDC_ISSUER=
NEXT_PUBLIC_QUSDT_CURRENCY=QUT
NEXT_PUBLIC_QUSDT_ISSUER=

# Public env vars (exposed to browser)
NEXT_PUBLIC_NETWORK_NAME=Falcon Ledger Testnet
NEXT_PUBLIC_NETWORK_ID=1001
NEXT_PUBLIC_DRIP_AMOUNT_QXRP=2000
NEXT_PUBLIC_RPC_URL=http://46.224.0.140:6005
NEXT_PUBLIC_EXPLORER_URL=